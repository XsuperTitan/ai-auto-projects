# DeepSeek API Key — 勿在代码中硬编码
DEEPSEEK_API_KEY=sk-your-key-here

# Orchestrator 认证令牌 — 必须与服务端的 ORCHESTRATOR_TOKEN 一致，切勿使用真实密钥
ORCHESTRATOR_TOKEN=CHANGE_ME_ORCHESTRATOR_TOKEN

# DeepSeek API 端点（可选，默认 https://api.deepseek.com/v1）
# DEEPSEEK_BASE=https://api.deepseek.com/v1

# CORS 允许的源（可选，默认 http://localhost:3000）
# ALLOWED_ORIGIN=http://localhost:3000

# 速率限制（可选，默认 10 次/分钟）
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW_MS=60000
